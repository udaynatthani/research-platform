generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DB_URL")
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  username           String          @unique
  passwordHash       String
  role               UserRole        @default(USER)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  chatSessions       AIChatSession[]
  auditLogs          AuditLog[]
  collections        Collection[]
  files              File[]
  notes              PaperNote[]
  projects           Project[]
  projectMemberships ProjectMember[]
  searchHistory      SearchHistory[]
  sessions           Session[]
  activities         UserActivity[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revoked      Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Project {
  id            String           @id @default(uuid())
  ownerId       String
  title         String
  description   String?
  visibility    Visibility       @default(PRIVATE)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  concepts      ConceptNode[]
  datasets      Dataset[]
  experiments   Experiment[]
  files         File[]
  insights      Insight[]
  paperNotes    PaperNote[]
  owner         User             @relation(fields: [ownerId], references: [id])
  members       ProjectMember[]
  sections      ProjectSection[]
  references    Reference[]
  workflowItems WorkflowItem[]
  workflows     WorkflowStage[]
  entityLinks   EntityLink[]
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String
  addedAt   DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model ProjectSection {
  id        String   @id @default(uuid())
  projectId String
  name      String
  type      String
  position  Int
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
}

model File {
  id              String              @id @default(uuid())
  uploadedById    String
  projectId       String?
  fileName        String
  originalName    String
  mimeType        String
  fileSize        Int
  storageProvider FileStorageProvider @default(LOCAL)
  storagePath     String
  url             String?
  entityType      EntityType
  entityId        String?
  checksum        String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  datasets        Dataset[]
  project         Project?            @relation(fields: [projectId], references: [id])
  uploader        User                @relation(fields: [uploadedById], references: [id])

  @@index([entityType, entityId])
}

model Paper {
  id              String            @id @default(uuid())
  externalId      String?
  source          String?
  title           String
  abstract        String?
  publicationYear Int?
  citationCount   Int?
  doi             String?
  url             String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  collections     CollectionPaper[]
  insights        Insight[]
  authors         PaperAuthor[]
  content         PaperContent?
  notes           PaperNote[]
  tags            PaperTag[]
}

model Author {
  id          String        @id @default(uuid())
  name        String
  affiliation String?
  orcid       String?
  papers      PaperAuthor[]
}

model PaperAuthor {
  paperId     String
  authorId    String
  authorOrder Int?
  author      Author @relation(fields: [authorId], references: [id])
  paper       Paper  @relation(fields: [paperId], references: [id])

  @@id([paperId, authorId])
}

model PaperContent {
  id               String   @id @default(uuid())
  paperId          String   @unique
  fullText         String
  extractionMethod String?
  createdAt        DateTime @default(now())
  paper            Paper    @relation(fields: [paperId], references: [id])
}

model Tag {
  id     String     @id @default(uuid())
  name   String     @unique
  papers PaperTag[]
}

model PaperTag {
  paperId String
  tagId   String
  paper   Paper  @relation(fields: [paperId], references: [id])
  tag     Tag    @relation(fields: [tagId], references: [id])

  @@id([paperId, tagId])
}

model Collection {
  id          String            @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id])
  papers      CollectionPaper[]
}

model CollectionPaper {
  id           String     @id @default(uuid())
  collectionId String
  paperId      String
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id])
  paper        Paper      @relation(fields: [paperId], references: [id])
}

model PaperNote {
  id        String   @id @default(uuid())
  paperId   String
  userId    String
  projectId String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  paper     Paper    @relation(fields: [paperId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Dataset {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  description String?
  fileId      String?
  createdAt   DateTime @default(now())
  file        File?    @relation(fields: [fileId], references: [id])
  project     Project  @relation(fields: [projectId], references: [id])
}

model Reference {
  id          String   @id @default(uuid())
  projectId   String
  title       String
  url         String?
  description String?
  type        String?
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id])
}

model WorkflowStage {
  id        String         @id @default(uuid())
  projectId String
  name      String
  position  Int
  createdAt DateTime       @default(now())
  items     WorkflowItem[]
  project   Project        @relation(fields: [projectId], references: [id])
}

model WorkflowItem {
  id          String         @id @default(uuid())
  stageId     String
  projectId   String
  title       String
  description String?
  entityType  EntityType
  entityId    String?
  status      WorkflowStatus @default(TODO)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  project     Project        @relation(fields: [projectId], references: [id])
  stage       WorkflowStage  @relation(fields: [stageId], references: [id])
}

model ConceptNode {
  id          String        @id @default(uuid())
  projectId   String
  type        String
  title       String
  description String?
  createdAt   DateTime      @default(now())
  outgoing    ConceptLink[] @relation("SourceNode")
  incoming    ConceptLink[] @relation("TargetNode")
  project     Project       @relation(fields: [projectId], references: [id])
}

model ConceptLink {
  id               String      @id @default(uuid())
  sourceNodeId     String
  targetNodeId     String
  relationshipType String
  createdAt        DateTime    @default(now())
  sourceNode       ConceptNode @relation("SourceNode", fields: [sourceNodeId], references: [id])
  targetNode       ConceptNode @relation("TargetNode", fields: [targetNodeId], references: [id])
}

model Experiment {
  id          String                @id @default(uuid())
  projectId   String
  title       String
  objective   String?
  methodology String?
  status      String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  project     Project               @relation(fields: [projectId], references: [id])
  iterations  ExperimentIteration[]
  insights    Insight[]
}

model ExperimentIteration {
  id              String             @id @default(uuid())
  experimentId    String
  iterationNumber Int
  description     String?
  createdAt       DateTime           @default(now())
  experiment      Experiment         @relation(fields: [experimentId], references: [id])
  results         ExperimentResult[]
}

model ExperimentResult {
  id                    String              @id @default(uuid())
  experimentIterationId String
  resultSummary         String?
  metrics               Json?
  createdAt             DateTime            @default(now())
  iteration             ExperimentIteration @relation(fields: [experimentIterationId], references: [id])
}

model Insight {
  id              String   @id @default(uuid())
  projectId       String
  paperId         String?
  experimentId    String?
  conceptNodeId   String?
  content         String
  confidenceScore Float?
  createdBy       String?
  createdAt       DateTime @default(now())
  paper           Paper?   @relation(fields: [paperId], references: [id])
  experiment      Experiment? @relation(fields: [experimentId], references: [id])
  project         Project  @relation(fields: [projectId], references: [id])
}

model AIChatSession {
  id        String          @id @default(uuid())
  userId    String
  paperId   String?
  createdAt DateTime        @default(now())
  messages  AIChatMessage[]
  user      User            @relation(fields: [userId], references: [id])
}

model AIChatMessage {
  id         String        @id @default(uuid())
  sessionId  String
  role       ChatRole
  message    String
  tokensUsed Int?
  createdAt  DateTime      @default(now())
  session    AIChatSession @relation(fields: [sessionId], references: [id])
}

model EntityLink {
  id               String   @id @default(uuid())
  projectId        String
  sourceType       String   // e.g., 'PAPER', 'EXPERIMENT'
  sourceId         String
  targetType       String
  targetId         String
  relationshipType String
  description      String?
  createdAt        DateTime @default(now())
  project          Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([sourceId])
  @@index([targetId])
}

model UserActivity {
  id           String   @id @default(uuid())
  userId       String
  activityType String
  entityType   String?
  entityId     String?
  metadata     Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model SearchHistory {
  id          String   @id @default(uuid())
  userId      String
  query       String
  filters     Json?
  resultCount Int?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

model ApiLog {
  id         String   @id @default(uuid())
  endpoint   String
  method     String
  statusCode Int
  latencyMs  Int?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model AILog {
  id         String   @id @default(uuid())
  userId     String?
  operation  String
  model      String?
  tokensUsed Int?
  cost       Float?
  createdAt  DateTime @default(now())
}



enum UserRole {
  USER
  ADMIN
}

enum Visibility {
  PRIVATE
  PUBLIC
}

enum FileStorageProvider {
  LOCAL
  S3
  R2
}

enum EntityType {
  PAPER
  DATASET
  EXPERIMENT
  NOTE
  PROJECT
}

enum WorkflowStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ChatRole {
  USER
  ASSISTANT
}
